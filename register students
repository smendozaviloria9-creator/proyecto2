# 2. Storage: We will use a list to store student dictionaries
students = []

def register_student():
    print("\n--- Register New Student ---")
    student_id = input("Unique ID: ")
    name = input("Name: ")
    age = input("Age: ")
    course = input("Course or program: ")
    # Default status is Active
    student = {
        "id": student_id,
        "name": name,
        "age": age,
        "course": course,
        "status": "Active"
    }
    students.append(student)
    print("Successfully registered student.")

def view_list():
    print("\n--- Student List ---")
    if not students:
        print("There are no registered students.")
    for st in students:
        print(f"ID: {st['id']} | Name: {st['name']} | Course: {st['course']} | Status: {st['status']}")

def search_student():
    print("\n--- Search Student ---")
    criteria = input("Enter ID or Name to search: ").lower()
    found = [s for s in students if criteria in s['id'].lower() or criteria in s['name'].lower()]
    
    if found:
        for st in found:
            print(st)
    else:
        print("No matches found.")

def update_student():
    student_id = input("\nEnter the ID of the student to be updated: ")
    for st in students:
        if st['id'] == student_id:
            print("Leave blank to avoid changing the current value.")
            st['name'] = input(f"New name ({st['name']}): ") or st['name']
            st['age'] = input(f"New age ({st['age']}): ") or st['age']
            st['course'] = input(f"New course ({st['course']}): ") or st['course']
            st['status'] = input(f"New status ({st['status']}): ") or st['status']
            print("Information updated.")
            return
    print("Student not found.")

def delete_student():
    student_id = input("\nEnter the ID of the student to be deleted: ")
    global students
    students = [s for s in students if s['id'] != student_id]
    print(f"Deletion process completed for ID: {student_id}")

# --- Main Menu ---
while True:
    print("\n--- MANAGEMENT SYSTEM (MENU) ---")
    print("1. Register | 2. View | 3. Search | 4. Update | 5. Delete | 6. Exit")
    option = input("Select an option: ")
    
    if option == '1': register_student()
    elif option == '2': view_list()
    elif option == '3': search_student()
    elif option == '4': update_student()
    elif option == '5': delete_student()
    elif option == '6': break
    else: print("Invalid option.")
